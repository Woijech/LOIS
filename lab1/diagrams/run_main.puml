@startuml
skinparam conditionEndStyle hline
start

:print("Парсер логических формул...");

while (True?) is (да)
  :raw_formula = input(...).strip();

  if (raw_formula.lower() == "exit"\nor raw_formula == ""?) then (да)
    :print("Завершение работы.");
    stop
  else (нет)
    if (parse_formula(raw_formula)\nвыбрасывает FormulaError?) then (да)
      :print(f"Ошибка: {error}");
    else (нет)
      :tree = parse_formula(raw_formula);
      :print(f"СКНФ: {'да' if is_sknf(tree) else 'нет'}");
    endif
  endif
endwhile (нет)

stop
@enduml
