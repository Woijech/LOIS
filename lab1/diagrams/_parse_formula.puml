@startdot _parse_formula_parser
digraph G {
  graph [rankdir=TB, bgcolor=white, nodesep=0.45, ranksep=0.5];
  node [
    fontname="Times New Roman",
    fontsize=12,
    color=black,
    penwidth=1.2,
    style=solid,
    margin="0.08,0.06"
  ];
  edge [
    fontname="Times New Roman",
    fontsize=11,
    color=black,
    penwidth=1.1,
    arrowsize=0.7
  ];
start [label="Начало", shape=oval];
  ret [label="Возврат Parser(text).parse()", shape=parallelogram];
  stop [label="Конец", shape=oval];

  start -> ret -> stop;
}
@enddot
