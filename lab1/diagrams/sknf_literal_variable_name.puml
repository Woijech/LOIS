@startdot literal_variable_name_sknf
digraph G {
  graph [rankdir=TB, bgcolor=white, nodesep=0.45, ranksep=0.5];
  node [
    fontname="Times New Roman",
    fontsize=12,
    color=black,
    penwidth=1.2,
    style=solid,
    margin="0.08,0.06"
  ];
  edge [
    fontname="Times New Roman",
    fontsize=11,
    color=black,
    penwidth=1.1,
    arrowsize=0.7
  ];
start [label="Начало", shape=oval];
  d_id [label="node - Identifier?", shape=diamond];
  ret_name [label="Возврат node.name", shape=parallelogram];
  d_unary [label="node - UnaryExpression\nи operator == '!'?", shape=diamond];
  d_operand [label="node.operand - Identifier?", shape=diamond];
  ret_operand [label="Возврат node.operand.name", shape=parallelogram];
  ret_none_1 [label="Возврат None", shape=parallelogram];
  ret_none_2 [label="Возврат None", shape=parallelogram];
  stop [label="Конец", shape=oval];

  start -> d_id;
  d_id:e -> ret_name [label="да"];
  ret_name -> stop;
  d_id:w -> d_unary [label="нет"];
  d_unary:e -> d_operand [label="да"];
  d_operand:e -> ret_operand [label="да"];
  ret_operand -> stop;
  d_operand:w -> ret_none_1 [label="нет"];
  ret_none_1 -> stop;
  d_unary:w -> ret_none_2 [label="нет"];
  ret_none_2 -> stop;
}
@enddot
