@startdot _match_Parser
digraph G {
  graph [rankdir=TB, bgcolor=white, splines=polyline, nodesep=0.45, ranksep=0.5];
  node [
    fontname="Times New Roman",
    fontsize=12,
    color=black,
    penwidth=1.2,
    style=solid,
    margin="0.08,0.06"
  ];
  edge [
    fontname="Times New Roman",
    fontsize=11,
    color=black,
    penwidth=1.1,
    arrowsize=0.7
  ];
start [label="Начало", shape=oval];
  d1 [label="self._current().token_type
== token_type?", shape=diamond];
  p1 [label="self._index += 1", shape=box];
  ret_true [label="Возврат True", shape=parallelogram];
  ret_false [label="Возврат False", shape=parallelogram];
  stop [label="Конец", shape=oval];

  start -> d1;
  d1:e -> p1 [label="да"];
  p1 -> ret_true -> stop;
  d1:w -> ret_false [label="нет"];
  ret_false -> stop;
}
@enddot
